{{!
    @template local_astusse/chat_app

    ASTUSSE self-contained chat application shell (sidebar, conversation area and
    composer). All copy is passed in already localised; jsonConfig carries the
    JSON bootstrap consumed by js/chat_app.js and is rendered unescaped.

    Context variables required for this template:
    * pageMode string - Page mode flag ("course" or "global").
    * brandSubtitle string - Sidebar brand subtitle.
    * newSessionButton string - Label of the new-session button.
    * userFullname string - Current user's full name.
    * userInitials string - Current user's initials for the avatar.
    * themeToggleLabel string - Accessible label for the theme toggle.
    * openSidebarLabel string - Accessible label to open the sidebar.
    * closeSidebarLabel string - Accessible label to close the sidebar.
    * conversationsLabel string - Heading for the conversation list.
    * statusReady string - Ready status text.
    * courseLabel string - Course selector label.
    * coursePlaceholder string - Course selector placeholder.
    * coursesAvailableLabel string - Label shown when courses are available.
    * agentLabel string - Agent selector label.
    * agentExplicatif string - Explanatory agent label.
    * agentSocratique string - Socratic agent label.
    * messageLabel string - Message field label.
    * messagePlaceholder string - Message field placeholder.
    * kbdEnter string - Enter key hint.
    * kbdShift string - Shift key hint.
    * hintSend string - Send hint text.
    * hintNewline string - New-line hint text.
    * searchPlaceholder string - Conversation search placeholder.
    * sendButton string - Send button label.
    * backUrl string - URL back to Moodle.
    * backLabel string - Label of the back link.
    * jsonConfig string - JSON bootstrap configuration (rendered unescaped).
    * fontsCssUrl string - URL of the bundled Geist font stylesheet.
    * markedUrl string - URL of the bundled Marked library.
    * chatAppJsUrl string - URL of the chat application script.

    Example context (json):
    {
        "pageMode": "course",
        "brandSubtitle": "AI tutor",
        "newSessionButton": "New conversation",
        "userFullname": "Jane Doe",
        "userInitials": "JD",
        "themeToggleLabel": "Toggle theme",
        "openSidebarLabel": "Open sidebar",
        "closeSidebarLabel": "Close sidebar",
        "conversationsLabel": "Conversations",
        "statusReady": "Ready",
        "courseLabel": "Course",
        "coursePlaceholder": "Select a course",
        "coursesAvailableLabel": "Courses available",
        "agentLabel": "Tutor mode",
        "agentExplicatif": "Explanatory",
        "agentSocratique": "Socratic",
        "messageLabel": "Your message",
        "messagePlaceholder": "Ask a question",
        "kbdEnter": "Enter",
        "kbdShift": "Shift",
        "hintSend": "to send",
        "hintNewline": "for a new line",
        "searchPlaceholder": "Search",
        "sendButton": "Send",
        "backUrl": "https://moodle.example.com/my/",
        "backLabel": "Back to Moodle",
        "jsonConfig": "{}",
        "fontsCssUrl": "https://moodle.example.com/local/astusse/fonts/geist.css",
        "markedUrl": "https://moodle.example.com/local/astusse/thirdparty/marked/marked.min.js",
        "chatAppJsUrl": "https://moodle.example.com/local/astusse/js/chat_app.js"
    }
}}
{{! Charte ASTUSSE « autoporteur » — Geist / Geist Mono, tokens clair+sombre }}
{{! Polices Geist embarquées localement (aucun appel externe). }}
<link rel="stylesheet" href="{{fontsCssUrl}}">

<div class="local-astusse-chatapp" id="local-astusse-chatapp" data-page-mode="{{pageMode}}" data-theme="light">

    {{! ── Sidebar ── }}
    <aside class="la-sidebar" id="local-astusse-chatapp-sidebar">
        <div class="la-sb-head">
            <div class="la-brand-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6.7 13.4C6.2 8.9 8.7 6 12 6s5.8 2.9 5.3 7.4"/>
                    <path d="M6.9 12.9c-2.1 1.2-3.2 3.4-2.4 5 .45.9 1.6.85 1.95-.25"/>
                    <path d="M9.4 13.7c-1.05 1.7-1.45 4-.5 5.4.55.8 1.6.6 1.7-.55"/>
                    <path d="M12 14c0 2.2-.05 3.95 0 5.5"/>
                    <path d="M14.6 13.7c1.05 1.7 1.45 4 .5 5.4-.55.8-1.6.6-1.7-.55"/>
                    <path d="M17.1 12.9c2.1 1.2 3.2 3.4 2.4 5-.45.9-1.6.85-1.95-.25"/>
                </svg>
            </div>
            <div class="la-brand-text">
                <span class="la-brand-name">ASTUSSE</span>
                <span class="la-brand-sub">{{brandSubtitle}}</span>
            </div>
            <button type="button" id="local-astusse-chatapp-sidebar-close"
                    class="la-icon-btn" aria-label="{{closeSidebarLabel}}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="la-sb-actions">
            <button type="button" id="local-astusse-chatapp-new" class="la-btn-new">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                {{newSessionButton}}
            </button>
        </div>

        <div class="la-sb-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7"/>
                <path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="search" id="local-astusse-chatapp-search"
                   placeholder="{{searchPlaceholder}}" aria-label="{{searchPlaceholder}}" autocomplete="off">
        </div>

        <nav class="la-sb-scroll" aria-label="{{conversationsLabel}}">
            <div class="la-sb-group-label">{{conversationsLabel}}</div>
            <div id="local-astusse-chatapp-threadlist"></div>
        </nav>

        <div class="la-sb-foot">
            <div class="la-avatar" aria-hidden="true">{{userInitials}}</div>
            <div class="la-who">
                <b>{{userFullname}}</b>
                <a href="{{backUrl}}">{{backLabel}}</a>
            </div>
        </div>
    </aside>

    {{! ── Main area ── }}
    <main class="la-main">

        {{! Top bar }}
        <header class="la-topbar">
            <button type="button" id="local-astusse-chatapp-sidebar-open"
                    class="la-icon-btn" aria-label="{{openSidebarLabel}}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M9 3v18"/>
                </svg>
            </button>

            <div class="la-course-wrap" id="local-astusse-chatapp-course-wrap">
                <button type="button" id="local-astusse-chatapp-course" class="la-course-select"
                        aria-haspopup="listbox" aria-expanded="false" aria-label="{{courseLabel}}">
                    <svg class="la-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                    <span class="la-label" id="local-astusse-chatapp-course-label">{{coursePlaceholder}}</span>
                    <svg class="la-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m6 9 6 6 6-6"/>
                    </svg>
                </button>
                <div class="la-menu" id="local-astusse-chatapp-course-menu" role="listbox"
                     aria-label="{{coursesAvailableLabel}}" hidden>
                    <div class="la-menu-label">{{coursesAvailableLabel}}</div>
                    <div id="local-astusse-chatapp-course-items"></div>
                </div>
            </div>

            <div class="la-tb-spacer"></div>

            <div class="la-segmented" id="local-astusse-chatapp-agent" role="group" aria-label="{{agentLabel}}">
                <button type="button" class="la-seg" data-agent="socratique">
                    <span class="la-seg-dot"></span>
                    <span class="la-seg-label">{{agentSocratique}}</span>
                </button>
                <button type="button" class="la-seg" data-agent="explicatif">
                    <span class="la-seg-dot"></span>
                    <span class="la-seg-label">{{agentExplicatif}}</span>
                </button>
            </div>

            <span id="local-astusse-chatapp-status" class="la-status-pill" role="status">
                <span class="la-live" aria-hidden="true"></span>
                <span class="la-status-text" id="local-astusse-chatapp-status-text">{{statusReady}}</span>
            </span>

            <button type="button" id="local-astusse-chatapp-theme" class="la-icon-btn" title="{{themeToggleLabel}}"
                    aria-label="{{themeToggleLabel}}"></button>
        </header>

        {{! Messages / empty state }}
        <div id="local-astusse-chatapp-messages" class="la-chat" aria-live="polite"></div>

        {{! Composer }}
        <div class="la-composer-wrap">
            <div class="la-composer" id="local-astusse-chatapp-composer">
                <div class="la-composer-top">
                    <textarea id="local-astusse-chatapp-input" rows="1"
                              placeholder="{{messagePlaceholder}}" aria-label="{{messageLabel}}"></textarea>
                    <button type="button" id="local-astusse-chatapp-send"
                            class="la-send-btn" aria-label="{{sendButton}}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="m22 2-7 20-4-9-9-4 20-7z"/>
                        </svg>
                    </button>
                </div>
            </div>
            <p class="la-composer-hint"><kbd>{{kbdEnter}}</kbd> {{hintSend}} · <kbd>{{kbdShift}}</kbd>+<kbd>{{kbdEnter}}</kbd> {{hintNewline}}</p>
        </div>

    </main>
</div>

<script>window.AstusseChatConfig = {{{jsonConfig}}};</script>
{{#markedUrl}}
<script src="{{markedUrl}}"></script>
{{/markedUrl}}
<script src="{{chatAppJsUrl}}"></script>
