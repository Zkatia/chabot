<div class="local-astusse-chatapp" data-page-mode="{{pageMode}}">

    {{! ── Sidebar ── }}
    <aside class="local-astusse-chatapp-sidebar" id="local-astusse-chatapp-sidebar">
        <div class="local-astusse-chatapp-sidebar-header">
            <a href="{{backUrl}}" class="local-astusse-chatapp-back-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                {{backLabel}}
            </a>
            <button type="button" id="local-astusse-chatapp-sidebar-close"
                    class="local-astusse-chatapp-sidebar-toggle" aria-label="Close sidebar">
                ✕
            </button>
        </div>

        <button type="button" id="local-astusse-chatapp-new" class="local-astusse-chatapp-new-btn">
            <span class="local-astusse-chatapp-new-icon">+</span>
            {{newSessionButton}}
        </button>

        <nav class="local-astusse-chatapp-threads">
            <div class="local-astusse-chatapp-threads-label">{{conversationsLabel}}</div>
            <div id="local-astusse-chatapp-threadlist" class="local-astusse-chatapp-threadlist"></div>
        </nav>

    </aside>

    {{! ── Main area ── }}
    <main class="local-astusse-chatapp-main">

        {{! Top bar }}
        <header class="local-astusse-chatapp-header">
            <button type="button" id="local-astusse-chatapp-sidebar-open"
                    class="local-astusse-chatapp-sidebar-toggle" aria-label="Open sidebar">
                ☰
            </button>
            <div class="local-astusse-chatapp-header-center">
                <select id="local-astusse-chatapp-course" class="local-astusse-chatapp-course-select"></select>
                <p id="local-astusse-chatapp-course-note" class="local-astusse-chatapp-header-note"></p>
            </div>
            <div class="local-astusse-chatapp-header-right">
                <label for="local-astusse-chatapp-agent" class="local-astusse-chatapp-agent-label">{{agentLabel}}</label>
                <select id="local-astusse-chatapp-agent" class="local-astusse-chatapp-agent-select">
                    <option value="explicatif">{{agentExplicatif}}</option>
                    <option value="socratique">{{agentSocratique}}</option>
                </select>
                <span id="local-astusse-chatapp-status" class="local-astusse-chatapp-status">
                    {{statusReady}}
                </span>
            </div>
        </header>

        {{! Context cards (hidden by default, shown when relevant) }}
        <section class="local-astusse-chatapp-context" aria-live="polite">
            <div class="local-astusse-chatapp-context-card">
                <span class="local-astusse-chatapp-context-label">{{courseContextLabel}}</span>
                <strong id="local-astusse-chatapp-course-context"></strong>
            </div>
            <div id="local-astusse-chatapp-reference-card" class="local-astusse-chatapp-context-card is-reference">
                <span class="local-astusse-chatapp-context-label">{{referenceTrainerTitle}}</span>
                <strong id="local-astusse-chatapp-reference-context"></strong>
            </div>
        </section>

        {{! Messages }}
        <div id="local-astusse-chatapp-messages" class="local-astusse-chatapp-messages" aria-live="polite"></div>

        {{! Composer }}
        <div class="local-astusse-chatapp-composer">
            <div class="local-astusse-chatapp-input-wrap">
                <textarea id="local-astusse-chatapp-input" rows="1"
                          placeholder="{{messagePlaceholder}}"></textarea>
                <button type="button" id="local-astusse-chatapp-send"
                        class="local-astusse-chatapp-send-btn" aria-label="{{sendButton}}">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <p class="local-astusse-chatapp-disclaimer">{{inputHint}}</p>
        </div>

    </main>
</div>

<script>window.AstusseChatConfig = {{{jsonConfig}}};</script>
{{#markedCdnUrl}}
<script src="{{markedCdnUrl}}"></script>
{{/markedCdnUrl}}
<script src="{{chatAppJsUrl}}"></script>
